{
  "name": "wwiirun",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "scripts": {
    "dev": "vite",
    "format": "prettier --write \"src/**/*.{ts,css}\" \"tests/**/*.{ts,css,html}\" \"scripts/**/*.ts\" \"*.{js,mjs,ts,json,html}\" \".github/workflows/*.yml\"",
    "format:check": "prettier --check \"src/**/*.{ts,css}\" \"tests/**/*.{ts,css,html}\" \"scripts/**/*.ts\" \"*.{js,mjs,ts,json,html}\" \".github/workflows/*.yml\"",
    "lint": "eslint --max-warnings 0 src tests scripts *.config.ts eslint.config.mjs",
    "typecheck:runtime": "tsc --project tsconfig.json --noEmit",
    "typecheck:tooling": "tsc --project tsconfig.test.json --noEmit",
    "typecheck": "npm run typecheck:runtime && npm run typecheck:tooling",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:determinism": "vitest run --config vitest.determinism.config.ts",
    "test:e2e": "playwright test && playwright test --config tests/performance/playwright.config.ts",
    "test:pwa": "playwright test --config tests/pwa/playwright.config.ts",
    "content:validate": "node scripts/validateContent.ts",
    "pwa:inspect": "node scripts/inspectPwaBuild.ts",
    "performance:budget": "node scripts/performanceBudget.ts",
    "performance:harness": "vite --config tests/performance/vite.config.ts",
    "build": "npm run typecheck && npm run content:validate && vite build && npm run pwa:inspect && npm run performance:budget",
    "preview": "vite preview",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test:unit && npm run test:determinism && npm run build"
  },
  "dependencies": {
    "phaser": "3.90.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.6.0",
    "prettier": "3.9.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.9"
  }
}
